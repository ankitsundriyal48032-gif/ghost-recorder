{
  "manifest_version": 3,
  "name": "Ghost Recorder",
  "version": "5.8.9",
  "description": "One-click AI meeting notes on any platform. Local recording, speaker transcripts, summaries, action items. Bring your own AI key.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "tabCapture",
    "offscreen",
    "storage",
    "unlimitedStorage",
    "notifications",
    "tabs",
    "downloads",
    "downloads.shelf",
    "downloads.ui"
  ],
  "host_permissions": [
    "*://*/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.groq.com/*",
    "https://openrouter.ai/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["inject.js", "inject-webrtc.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [{
    "resources": ["mic-permission.html"],
    "matches": ["*://*/*"]
  }],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" } },
  "options_page": "dashboard.html"
}
